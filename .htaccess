# Celsior static site on Apache/cPanel
DirectoryIndex index.html
Options -Indexes

# ------------------------------------------------------------
# Static-site cache policy
# HTML gets a short cache. Static assets get long cache.
# ------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
    Header unset Pragma
  </FilesMatch>

  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico|mp4|webm|woff|woff2|ttf|otf|pdf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html A300
  ExpiresByType text/css A31557600
  ExpiresByType text/javascript A31557600
  ExpiresByType application/javascript A31557600
  ExpiresByType image/jpg A31557600
  ExpiresByType image/jpeg A31557600
  ExpiresByType image/png A31557600
  ExpiresByType image/gif A31557600
  ExpiresByType image/webp A31557600
  ExpiresByType image/avif A31557600
  ExpiresByType image/svg+xml A31557600
  ExpiresByType video/mp4 A31557600
  ExpiresByType video/webm A31557600
  ExpiresByType font/woff A31557600
  ExpiresByType font/woff2 A31557600
  ExpiresByType application/font-woff A31557600
  ExpiresByType application/font-woff2 A31557600
</IfModule>

# ------------------------------------------------------------
# Compression for static site
# Note: applies only if server-level mod_deflate is enabled.
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

# ------------------------------------------------------------
# Legacy URL redirects from previous/static/Vercel routes
# ------------------------------------------------------------

RewriteRule ^ai-innovation/frameworks-accelerators/synthetix/?$ /ai-innovation/synthetix [R=301,L]
RewriteRule ^ai-innovation/ai-innovation/frameworks-accelerators/synthetix/?$ /ai-innovation/synthetix [R=301,L]

RewriteRule ^frameworks-accelerators/synthetix/?$ /ai-innovation/synthetix [R=301,L]
RewriteRule ^frameworks-accelerators/?$ /ai-innovation/frameworks-accelerators [R=301,L]

RewriteRule ^partner-ecosystem/?$ /partners [R=301,L]

# ------------------------------------------------------------
# Clean .html URLs
# Example: /about.html -> /about
# ------------------------------------------------------------

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ------------------------------------------------------------
# Serve extensionless .html files if they exist
# Example: /some-page -> /some-page.html
# ------------------------------------------------------------

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ------------------------------------------------------------
# Serve folder-based pages cleanly
# Example: /contact-us -> /contact-us/index.html
# ------------------------------------------------------------

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ $1/index.html [L]

</IfModule>
